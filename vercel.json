{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "buildCommand": "npm run prisma:deploy && npm run build",
  "crons": [
    {
      "path": "/api/jobs/process",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/jobs/mini-session-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/jobs/r2-cleanup",
      "schedule": "30 3 * * *"
    }
  ]
}
