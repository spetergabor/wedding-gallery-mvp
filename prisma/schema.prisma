generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Gallery {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  password     String?
  isActive     Boolean  @default(false)
  coverPhotoId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photos       Photo[]
  downloads    GalleryDownload[]
  views        GalleryView[]
}

model Photo {
  id           String   @id @default(cuid())
  galleryId    String
  filename     String
  r2Key        String   @default("")
  imageUrl     String
  thumbnailUrl String
  sortOrder    Int      @default(0)
  capturedAt   DateTime?
  createdAt    DateTime @default(now())
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([r2Key])
  @@index([galleryId, sortOrder])
  @@index([capturedAt])
}

model GalleryDownload {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  createdAt DateTime @default(now())
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([email])
}

model GalleryView {
  id          String   @id @default(cuid())
  galleryId   String
  country     String?
  region      String?
  city        String?
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([createdAt])
  @@index([country])
}
