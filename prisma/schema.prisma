generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("photographer")
  status       String   @default("pending")
  approvedAt   DateTime?
  approvedById String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  galleries    Gallery[]
  customers    Customer[]
  notifications AdminNotification[]
  siteSettings SiteSettings?
}

model AdminNotification {
  id        String   @id @default(cuid())
  adminId   String?
  type      String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([readAt])
  @@index([createdAt])
}

model SiteSettings {
  id             String   @id @default("default")
  adminId        String?  @unique
  businessName   String   @default("")
  logoUrl        String?
  logoR2Key      String?
  signatureUrl   String?
  signatureR2Key String?
  websiteUrl     String?
  instagramUrl   String?
  facebookUrl    String?
  tiktokUrl      String?
  youtubeUrl     String?
  contactEmail   String?
  contactPhone   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  admin          Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model Customer {
  id             String   @id @default(cuid())
  adminId        String?
  customerType   String   @default("wedding_couple")
  coupleName     String
  primaryEmail   String
  secondaryEmail String?
  phone          String?
  weddingDate    DateTime?
  venue          String?
  status         String   @default("lead")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  admin          Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  contracts      Contract[]
  invoices       CustomerInvoice[]
  galleries      Gallery[]
  projects       CustomerProject[]
  albumReviews   AlbumReview[]
  albumDesigns   AlbumDesign[]

  @@index([adminId])
  @@index([customerType])
  @@index([status])
  @@index([weddingDate])
  @@index([primaryEmail])
}

model CustomerProject {
  id           String   @id @default(cuid())
  customerId   String
  title        String
  projectType  String   @default("general")
  status       String   @default("planned")
  eventDate    DateTime?
  venue        String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contracts    Contract[]
  invoices     CustomerInvoice[]
  galleries    Gallery[]
  albumReviews AlbumReview[]
  albumDesigns AlbumDesign[]

  @@index([customerId])
  @@index([projectType])
  @@index([status])
  @@index([eventDate])
}

model AlbumReview {
  id          String   @id @default(cuid())
  customerId  String
  projectId   String?
  title       String   @default("Album ellenőrző")
  status      String   @default("draft")
  accessToken String   @unique
  clientEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  spreads     AlbumReviewSpread[]

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([accessToken])
}

model AlbumReviewSpread {
  id          String   @id @default(cuid())
  reviewId    String
  title       String?
  filename    String
  r2Key       String
  imageUrl    String
  fileSize    Int      @default(0)
  imageWidth  Int      @default(0)
  imageHeight Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  review      AlbumReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  comments    AlbumReviewComment[]

  @@index([reviewId])
  @@index([reviewId, sortOrder])
  @@index([r2Key])
}

model AlbumReviewComment {
  id        String   @id @default(cuid())
  spreadId  String
  x         Float
  y         Float
  text      String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  spread    AlbumReviewSpread @relation(fields: [spreadId], references: [id], onDelete: Cascade)

  @@index([spreadId])
  @@index([status])
  @@index([createdAt])
}

model AlbumDesign {
  id             String   @id @default(cuid())
  customerId     String
  projectId      String?
  favoriteListId String?
  title          String   @default("Albumterv")
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project        CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  favoriteList   GalleryFavoriteList? @relation(fields: [favoriteListId], references: [id], onDelete: SetNull)
  spreads        AlbumDesignSpread[]

  @@index([customerId])
  @@index([projectId])
  @@index([favoriteListId])
  @@index([status])
  @@index([createdAt])
}

model AlbumDesignSpread {
  id        String   @id @default(cuid())
  designId  String
  title     String?
  layoutKey String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  design    AlbumDesign @relation(fields: [designId], references: [id], onDelete: Cascade)
  items     AlbumDesignSpreadItem[]

  @@index([designId])
  @@index([designId, sortOrder])
}

model AlbumDesignSpreadItem {
  id        String   @id @default(cuid())
  spreadId  String
  photoId   String
  slotIndex Int      @default(0)
  x         Float
  y         Float
  width     Float
  height    Float
  cropX     Float    @default(50)
  cropY     Float    @default(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  spread    AlbumDesignSpread @relation(fields: [spreadId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([spreadId])
  @@index([photoId])
  @@index([spreadId, slotIndex])
}

model Contract {
  id          String   @id @default(cuid())
  customerId  String
  projectId   String?
  title       String
  status      String   @default("draft")
  sourceType  String   @default("pdf")
  originalFilename String
  r2Key       String
  fileUrl     String
  fileSize    Int      @default(0)
  bodyText    String?
  clientFields Json?
  completedFields Json?
  accessToken String?  @unique
  accessTokenExpiresAt DateTime?
  sentAt      DateTime?
  openedAt    DateTime?
  signedAt    DateTime?
  signedR2Key String?
  signedFileUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
  @@index([accessToken])
}

model CustomerInvoice {
  id               String   @id @default(cuid())
  customerId       String
  projectId        String?
  title            String
  status           String   @default("open")
  originalFilename String
  r2Key            String
  fileUrl          String
  fileSize         Int      @default(0)
  amountCents      Int?
  currency         String   @default("EUR")
  dueDate          DateTime?
  notes            String?
  sentAt           DateTime?
  sentTo           String?
  emailError       String?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project          CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([sentAt])
  @@index([paidAt])
  @@index([createdAt])
}

model Gallery {
  id           String   @id @default(cuid())
  adminId      String?
  customerId   String?
  projectId    String?
  title        String
  slug         String   @unique
  password     String?
  eventDate    DateTime?
  isActive     Boolean  @default(false)
  galleryMode  String   @default("full")
  proofingStatus String @default("not_opened")
  proofingStatusUpdatedAt DateTime?
  downloadsEnabled Boolean @default(true)
  coverPhotoId String?
  clientEmail  String?
  clientAccessToken String? @unique
  proofingInviteSentAt DateTime?
  proofingInviteSentTo String?
  proofingInviteEmailError String?
  finalDeliveryEmailSentAt DateTime?
  finalDeliveryEmailSentTo String?
  finalDeliveryEmailError String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photos       Photo[]
  downloads    GalleryDownload[]
  downloadPackages GalleryDownloadPackage[]
  views        GalleryView[]
  favoriteLists GalleryFavoriteList[]
  uploadSessions GalleryUploadSession[]
  mediaProcessingJobs MediaProcessingJob[]
  admin        Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  project      CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([customerId])
  @@index([projectId])
  @@index([galleryMode])
  @@index([proofingStatus])
}

model Photo {
  id           String   @id @default(cuid())
  galleryId    String
  filename     String
  r2Key        String   @default("")
  imageUrl     String
  thumbnailUrl String
  previewUrl   String   @default("")
  deliveryStage String  @default("final")
  mediaType    String   @default("image")
  processingStatus String @default("ready")
  processingError  String?
  processingRequestedAt DateTime?
  processingCompletedAt DateTime?
  fileSize     Int      @default(0)
  imageWidth   Int      @default(0)
  imageHeight  Int      @default(0)
  sortOrder    Int      @default(0)
  capturedAt   DateTime?
  isClientHidden Boolean @default(false)
  clientHiddenAt DateTime?
  createdAt    DateTime @default(now())
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  favoriteItems GalleryFavoriteItem[]
  processingJobs MediaProcessingJob[]
  albumDesignItems AlbumDesignSpreadItem[]

  @@index([galleryId])
  @@index([r2Key])
  @@index([galleryId, sortOrder])
  @@index([galleryId, deliveryStage])
  @@index([capturedAt])
  @@index([processingStatus])
}

model MediaProcessingJob {
  id           String   @id @default(cuid())
  galleryId    String
  photoId      String
  mediaType    String
  status       String   @default("pending")
  sourceR2Key  String
  thumbnailR2Key String?
  previewR2Key   String?
  posterR2Key    String?
  attempts     Int      @default(0)
  errorMessage String?
  claimedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photo        Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([photoId])
  @@index([status])
  @@index([createdAt])
  @@index([claimedAt])
}

model GalleryDownload {
  id        String   @id @default(cuid())
  galleryId String
  packageId String?
  email     String
  status    String   @default("recorded")
  downloadLinkSentAt DateTime?
  downloadLinkEmailError String?
  createdAt DateTime @default(now())
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  package   GalleryDownloadPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([galleryId])
  @@index([packageId])
  @@index([email])
  @@index([status])
}

model GalleryDownloadPackage {
  id           String   @id @default(cuid())
  galleryId    String
  scope        String   @default("public")
  status       String   @default("pending")
  photoCount   Int      @default(0)
  partIndex    Int      @default(0)
  partCount    Int      @default(1)
  photoOffset  Int      @default(0)
  photoLimit   Int?
  groupId      String?
  fileSize     BigInt   @default(0)
  processedCount Int     @default(0)
  processedBytes BigInt  @default(0)
  r2Key        String?
  downloadUrl  String?
  accessToken  String?  @unique
  accessTokenExpiresAt DateTime?
  linkCreatedAt DateTime?
  errorMessage String?
  generatedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  downloads    GalleryDownload[]

  @@index([galleryId])
  @@index([galleryId, scope])
  @@index([groupId])
  @@index([status])
  @@index([generatedAt])
}

model BackgroundJob {
  id           String   @id @default(cuid())
  type         String
  status       String   @default("pending")
  payload      Json
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  errorMessage String?
  lockedAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([lockedAt])
}

model GalleryView {
  id          String   @id @default(cuid())
  galleryId   String
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([createdAt])
  @@index([country])
}

model GalleryFavoriteList {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  name      String   @default("Favoriten")
  submittedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items     GalleryFavoriteItem[]
  albumDesigns AlbumDesign[]

  @@unique([galleryId, email, name])
  @@index([galleryId])
  @@index([email])
  @@index([submittedAt])
}

model GalleryFavoriteItem {
  id        String   @id @default(cuid())
  listId    String
  photoId   String
  createdAt DateTime @default(now())
  list      GalleryFavoriteList @relation(fields: [listId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([listId, photoId])
  @@index([photoId])
}

model GalleryUploadSession {
  id             String   @id @default(cuid())
  galleryId      String
  status         String   @default("pending")
  deliveryStage  String   @default("final")
  totalCount     Int      @default(0)
  uploadedCount  Int      @default(0)
  completedCount Int      @default(0)
  failedCount    Int      @default(0)
  baseSortOrder  Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  gallery        Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items          GalleryUploadItem[]

  @@index([galleryId])
  @@index([status])
  @@index([createdAt])
}

model GalleryUploadItem {
  id            String   @id @default(cuid())
  sessionId     String
  clientId      String
  filename      String
  deliveryStage String   @default("final")
  r2Key         String?
  imageUrl      String?
  thumbnailUrl  String?
  previewUrl    String?
  mediaType     String   @default("image")
  fileSize      Int      @default(0)
  imageWidth    Int      @default(0)
  imageHeight   Int      @default(0)
  capturedAt    DateTime?
  originalIndex Int      @default(0)
  status        String   @default("pending")
  errorMessage  String?
  uploadedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  session       GalleryUploadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, clientId])
  @@index([sessionId])
  @@index([status])
  @@index([filename])
}
