generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  legalName    String?
  birthDate    DateTime?
  birthPlace   String?
  phone        String?
  addressLine  String?
  postalCode   String?
  city         String?
  country      String?
  taxNumber    String?
  businessRegistrationNumber String?
  profileNotes String?
  role         String   @default("photographer")
  status       String   @default("pending")
  approvedAt   DateTime?
  approvedById String?
  onboardingCompletedAt DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  galleries    Gallery[]
  customers    Customer[]
  notifications AdminNotification[]
  calendarBlocks AdminCalendarBlock[]
  googleCalendarIntegration GoogleCalendarIntegration?
  siteSettings SiteSettings?
  leads        Lead[]
  miniSessions MiniSession[]
  teamMembers  AdminTeamMembership[] @relation("TeamOwner")
  teamMembership AdminTeamMembership? @relation("TeamMember")
  passwordResetTokens AdminPasswordResetToken[]
  systemEventsAsActor SystemEvent[] @relation("SystemEventActor")
  systemEventsAsTarget SystemEvent[] @relation("SystemEventTarget")
  deliveryLogs DeliveryLog[]
  stripeConnectIntegration StripeConnectIntegration?
  galleryPurchases GalleryPurchase[]
  albumDesigns AlbumDesign[]
  planOverride AdminPlanOverride?
}

model SubscriptionPlan {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  description        String?
  monthlyPriceCents  Int      @default(0)
  currency           String   @default("EUR")
  storageLimitGb     Int?
  featureGallery     Boolean  @default(true)
  featureAlbum       Boolean  @default(false)
  featureContracts   Boolean  @default(false)
  featureBooking     Boolean  @default(false)
  featureStripe      Boolean  @default(false)
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  adminOverrides     AdminPlanOverride[]

  @@index([isActive])
  @@index([sortOrder])
}

model AdminPlanOverride {
  id                       String   @id @default(cuid())
  adminId                  String   @unique
  planId                   String?
  freeAccess               Boolean  @default(false)
  storageLimitGbOverride   Int?
  featureGalleryOverride   Boolean?
  featureAlbumOverride     Boolean?
  featureContractsOverride Boolean?
  featureBookingOverride   Boolean?
  featureStripeOverride    Boolean?
  notes                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  admin                    Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  plan                     SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([freeAccess])
}

model AdminPasswordResetToken {
  id        String   @id @default(cuid())
  adminId   String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([createdAt])
}

model RateLimitBucket {
  id             String   @id @default(cuid())
  scope          String
  identifierHash String
  count          Int      @default(0)
  resetAt        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([scope, identifierHash])
  @@index([resetAt])
  @@index([updatedAt])
}

model AdminTeamMembership {
  id           String   @id @default(cuid())
  ownerAdminId String
  memberAdminId String   @unique
  createdAt    DateTime @default(now())
  owner        Admin    @relation("TeamOwner", fields: [ownerAdminId], references: [id], onDelete: Cascade)
  member       Admin    @relation("TeamMember", fields: [memberAdminId], references: [id], onDelete: Cascade)

  @@unique([ownerAdminId, memberAdminId])
  @@index([ownerAdminId])
  @@index([memberAdminId])
  @@index([createdAt])
}

model AdminNotification {
  id        String   @id @default(cuid())
  adminId   String
  type      String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([readAt])
  @@index([createdAt])
}

model SystemEvent {
  id            String   @id @default(cuid())
  actorAdminId  String?
  targetAdminId String?
  type          String
  title         String
  message       String?
  severity      String   @default("info")
  status        String   @default("success")
  source        String?
  href          String?
  metadata      Json?
  createdAt     DateTime @default(now())
  actorAdmin    Admin?   @relation("SystemEventActor", fields: [actorAdminId], references: [id], onDelete: SetNull)
  targetAdmin   Admin?   @relation("SystemEventTarget", fields: [targetAdminId], references: [id], onDelete: SetNull)

  @@index([actorAdminId, createdAt])
  @@index([targetAdminId, createdAt])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model DeliveryLog {
  id                String   @id @default(cuid())
  adminId           String
  channel           String
  type              String
  status            String   @default("pending")
  recipient         String?
  subject           String?
  provider          String?
  providerMessageId String?
  entityType        String?
  entityId          String?
  attemptCount      Int      @default(0)
  maxAttempts       Int      @default(3)
  lastError         String?
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  admin             Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([adminId, status])
  @@index([channel, status])
  @@index([entityType, entityId])
  @@index([type])
  @@index([nextAttemptAt])
}

model AdminCalendarBlock {
  id        String   @id @default(cuid())
  adminId   String
  title     String
  startsAt  DateTime
  endsAt    DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([startsAt])
  @@index([endsAt])
  @@index([adminId, startsAt])
}

model GoogleCalendarIntegration {
  id                       String   @id @default(cuid())
  adminId                  String   @unique
  googleAccountEmail       String?
  googleAccountId          String?
  calendarId               String   @default("primary")
  calendarSummary          String?
  accessTokenEncrypted     String?
  refreshTokenEncrypted    String?
  accessTokenExpiresAt     DateTime?
  scope                    String?
  syncMiniSessionBookings  Boolean  @default(true)
  syncCustomerProjects     Boolean  @default(true)
  blockAvailabilityFromGoogleCalendar Boolean  @default(false)
  deleteCancelledEvents    Boolean  @default(true)
  lastSyncError            String?
  connectedAt              DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  admin                    Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([googleAccountEmail])
}

model StripeConnectIntegration {
  id                  String   @id @default(cuid())
  adminId             String   @unique
  stripeAccountId     String   @unique
  stripeAccountEmail  String?
  country             String?
  defaultCurrency     String?
  chargesEnabled      Boolean  @default(false)
  payoutsEnabled      Boolean  @default(false)
  detailsSubmitted    Boolean  @default(false)
  onboardingCompletedAt DateTime?
  lastSyncError       String?
  connectedAt         DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  admin               Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([stripeAccountId])
  @@index([chargesEnabled])
}

model SiteSettings {
  id             String   @id @default("default")
  adminId        String?  @unique
  businessName   String   @default("")
  publicSubdomain String?  @unique
  logoUrl        String?
  logoR2Key      String?
  logoHeight     Int      @default(80)
  signatureUrl   String?
  signatureR2Key String?
  websiteUrl     String?
  instagramUrl   String?
  facebookUrl    String?
  tiktokUrl      String?
  youtubeUrl     String?
  contactEmail   String?
  contactPhone   String?
  galleryWatermarkEnabled Boolean @default(false)
  galleryWatermarkText    String?
  galleryWatermarkPosition String @default("center")
  galleryWatermarkOpacity Int    @default(32)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  admin          Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model Customer {
  id             String   @id @default(cuid())
  adminId        String
  customerType   String   @default("wedding_couple")
  coupleName     String
  primaryEmail   String
  secondaryEmail String?
  phone          String?
  weddingDate    DateTime?
  venue          String?
  preferredLanguage String @default("de")
  portalToken    String?  @unique
  wifeName       String?
  wifeEmail      String?
  wifePhone      String?
  husbandName    String?
  husbandEmail   String?
  husbandPhone   String?
  partnerName    String?
  partnerEmail   String?
  partnerPhone   String?
  weddingLocation String?
  weddingAddress String?
  gettingReadyLocation String?
  churchCeremonyLocation String?
  civilCeremonyLocation String?
  mainLocation   String?
  ceremonyLocation String?
  receptionLocation String?
  weddingSchedule String?
  weddingStyleNotes String?
  importantPeopleNotes String?
  portalNotes    String?
  status         String   @default("lead")
  tags           String[] @default([])
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  admin          Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  contracts      Contract[]
  invoices       CustomerInvoice[]
  galleries      Gallery[]
  projects       CustomerProject[]
  meetings       CustomerMeeting[]
  tasks          CustomerTask[]
  miniSessionBookings MiniSessionBooking[]
  albumReviews   AlbumReview[]
  albumDesigns   AlbumDesign[]
  portalImages   CustomerPortalImage[]
  vendors        CustomerVendor[]

  @@index([adminId])
  @@index([customerType])
  @@index([status])
  @@index([weddingDate])
  @@index([primaryEmail])
}

model CustomerMeeting {
  id           String   @id @default(cuid())
  customerId   String
  title        String
  meetingType  String   @default("consultation")
  status       String   @default("planned")
  eventDate    DateTime
  startTime    String
  endTime      String
  location     String?
  notes        String?
  googleCalendarEventId String?
  googleCalendarId      String?
  googleCalendarSyncedAt DateTime?
  googleCalendarSyncError String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([meetingType])
  @@index([status])
  @@index([eventDate])
  @@index([googleCalendarEventId])
}

model CustomerTask {
  id          String   @id @default(cuid())
  customerId  String
  projectId   String?
  title       String
  taskType    String   @default("general")
  status      String   @default("open")
  priority    String   @default("normal")
  dueDate     DateTime?
  dueTime     String?
  notes       String?
  completedAt DateTime?
  googleCalendarEventId String?
  googleCalendarId      String?
  googleCalendarSyncedAt DateTime?
  googleCalendarSyncError String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([projectId])
  @@index([taskType])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([googleCalendarEventId])
}

model CustomerPortalImage {
  id               String   @id @default(cuid())
  customerId       String
  title            String?
  notes            String?
  originalFilename String
  imageUrl         String
  r2Key            String
  fileSize         Int      @default(0)
  contentType      String?
  uploadedBy       String   @default("client")
  createdAt        DateTime @default(now())
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

model CustomerVendor {
  id          String   @id @default(cuid())
  customerId  String
  role        String
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([role])
}

model Lead {
  id           String   @id @default(cuid())
  adminId      String
  name         String
  email        String?
  phone        String?
  eventType    String   @default("wedding")
  eventDate    DateTime?
  venue        String?
  status       String   @default("requested")
  notes        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([status])
  @@index([sortOrder])
  @@index([eventDate])
  @@index([email])
}

model MiniSession {
  id              String   @id @default(cuid())
  adminId         String
  title           String
  slug            String   @unique
  location        String
  bookingMode       String   @default("single_day")
  bookingWindowDays Int      @default(60)
  sessionDate       DateTime
  startsAt          DateTime
  endsAt            DateTime
  durationMinutes         Int
  minBookingNoticeMinutes Int      @default(0)
  language                String   @default("hu")
  isActive                Boolean  @default(true)
  createCustomerOnBooking Boolean  @default(true)
  notes                   String?
  stylingNotes            String?
  coverImageUrl           String?
  coverImageR2Key         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  admin             Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  bookings          MiniSessionBooking[]
  availabilityRules MiniSessionAvailability[]

  @@index([adminId])
  @@index([slug])
  @@index([bookingMode])
  @@index([sessionDate])
  @@index([startsAt])
  @@index([isActive])
}

model MiniSessionAvailability {
  id            String   @id @default(cuid())
  miniSessionId String
  weekday       Int
  startsAt      String
  endsAt        String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  miniSession   MiniSession @relation(fields: [miniSessionId], references: [id], onDelete: Cascade)

  @@index([miniSessionId])
  @@index([miniSessionId, weekday])
  @@index([isActive])
}

model MiniSessionBooking {
  id              String   @id @default(cuid())
  miniSessionId   String
  customerId      String?
  projectId       String?
  name            String
  email           String
  phone           String
  attendeeCount   Int
  startsAt        DateTime
  endsAt          DateTime
  status          String   @default("booked")
  source          String   @default("client")
  adminNote       String?
  cancelToken     String   @unique
  customerEmailSentAt DateTime?
  adminEmailSentAt    DateTime?
  reminderEmailSentAt DateTime?
  cancelledAt     DateTime?
  cancellationEmailSentAt DateTime?
  googleCalendarEventId String?
  googleCalendarId      String?
  googleCalendarSyncedAt DateTime?
  googleCalendarSyncError String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  miniSession     MiniSession @relation(fields: [miniSessionId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  project         CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([miniSessionId])
  @@index([customerId])
  @@index([projectId])
  @@index([miniSessionId, startsAt])
  @@index([status])
  @@index([status, startsAt, reminderEmailSentAt])
  @@index([source])
  @@index([email])
  @@index([cancelToken])
  @@index([googleCalendarEventId])
}

model CustomerProject {
  id           String   @id @default(cuid())
  customerId   String
  title        String
  projectType  String   @default("general")
  status       String   @default("planned")
  eventDate    DateTime?
  startTime    String?
  endTime      String?
  venue        String?
  notes        String?
  googleCalendarEventId String?
  googleCalendarId      String?
  googleCalendarSyncedAt DateTime?
  googleCalendarSyncError String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contracts    Contract[]
  invoices     CustomerInvoice[]
  galleries    Gallery[]
  albumReviews AlbumReview[]
  albumDesigns AlbumDesign[]
  tasks        CustomerTask[]
  miniSessionBookings MiniSessionBooking[]

  @@index([customerId])
  @@index([projectType])
  @@index([status])
  @@index([eventDate])
  @@index([googleCalendarEventId])
}

model AlbumReview {
  id          String   @id @default(cuid())
  customerId  String
  projectId   String?
  title       String   @default("Album ellenőrző")
  status      String   @default("draft")
  accessToken String   @unique
  clientEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  spreads     AlbumReviewSpread[]

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([accessToken])
}

model AlbumReviewSpread {
  id          String   @id @default(cuid())
  reviewId    String
  title       String?
  filename    String
  r2Key       String
  imageUrl    String
  fileSize    Int      @default(0)
  imageWidth  Int      @default(0)
  imageHeight Int      @default(0)
  sortOrder   Int      @default(0)
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  review      AlbumReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  comments    AlbumReviewComment[]

  @@index([reviewId])
  @@index([reviewId, sortOrder])
  @@index([r2Key])
}

model AlbumReviewComment {
  id        String   @id @default(cuid())
  spreadId  String
  x         Float
  y         Float
  text      String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  spread    AlbumReviewSpread @relation(fields: [spreadId], references: [id], onDelete: Cascade)

  @@index([spreadId])
  @@index([status])
  @@index([createdAt])
}

model AlbumDesign {
  id             String   @id @default(cuid())
  adminId        String?
  customerId     String?
  projectId      String?
  favoriteListId String?
  sourceGalleryId String?
  title          String   @default("Albumterv")
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  admin          Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project        CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  favoriteList   GalleryFavoriteList? @relation(fields: [favoriteListId], references: [id], onDelete: SetNull)
  sourceGallery  Gallery? @relation("AlbumDesignSourceGallery", fields: [sourceGalleryId], references: [id], onDelete: SetNull)
  spreads        AlbumDesignSpread[]

  @@index([adminId])
  @@index([customerId])
  @@index([projectId])
  @@index([favoriteListId])
  @@index([sourceGalleryId])
  @@index([status])
  @@index([createdAt])
}

model AlbumDesignSpread {
  id        String   @id @default(cuid())
  designId  String
  title     String?
  layoutKey String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  design    AlbumDesign @relation(fields: [designId], references: [id], onDelete: Cascade)
  items     AlbumDesignSpreadItem[]

  @@index([designId])
  @@index([designId, sortOrder])
}

model AlbumDesignSpreadItem {
  id        String   @id @default(cuid())
  spreadId  String
  photoId   String
  slotIndex Int      @default(0)
  x         Float
  y         Float
  width     Float
  height    Float
  cropX     Float    @default(50)
  cropY     Float    @default(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  spread    AlbumDesignSpread @relation(fields: [spreadId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([spreadId])
  @@index([photoId])
  @@index([spreadId, slotIndex])
}

model Contract {
  id          String   @id @default(cuid())
  customerId  String
  projectId   String?
  title       String
  status      String   @default("draft")
  sourceType  String   @default("pdf")
  originalFilename String
  r2Key       String
  fileUrl     String
  fileSize    Int      @default(0)
  bodyText    String?
  clientFields Json?
  completedFields Json?
  accessToken String?  @unique
  accessTokenExpiresAt DateTime?
  sentAt      DateTime?
  openedAt    DateTime?
  signedAt    DateTime?
  signedR2Key String?
  signedFileUrl String?
  documentHash String?
  signedPdfHash String?
  signatureIpAddress String?
  signatureUserAgent String?
  acceptedTermsAt DateTime?
  acceptedPrivacyAt DateTime?
  auditTrail Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
  @@index([accessToken])
}

model CustomerInvoice {
  id               String   @id @default(cuid())
  customerId       String
  projectId        String?
  title            String
  status           String   @default("open")
  originalFilename String
  r2Key            String
  fileUrl          String
  fileSize         Int      @default(0)
  amountCents      Int?
  currency         String   @default("EUR")
  dueDate          DateTime?
  notes            String?
  sentAt           DateTime?
  sentTo           String?
  emailError       String?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project          CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([sentAt])
  @@index([paidAt])
  @@index([createdAt])
}

model Gallery {
  id           String   @id @default(cuid())
  adminId      String
  customerId   String?
  projectId    String?
  title        String
  slug         String   @unique
  password     String?
  eventDate    DateTime?
  isActive     Boolean  @default(false)
  galleryMode  String   @default("full")
  galleryDesign String  @default("classic")
  galleryTextColor String?
  galleryTitleFont String @default("playfair")
  galleryTitleSize Int    @default(96)
  classicGradientIntensity Int @default(100)
  showContactBox Boolean @default(true)
  deliveryMode String   @default("free_download")
  salePriceCents Int    @default(0)
  saleUnitPriceCents Int @default(0)
  salePricingTiers Json?
  saleCurrency String   @default("eur")
  proofingStatus String @default("not_opened")
  proofingStatusUpdatedAt DateTime?
  downloadsEnabled Boolean @default(true)
  coverPhotoId String?
  coverPositionX Int      @default(50)
  coverPositionY Int      @default(50)
  publicColumnCount Int    @default(1)
  publicGridGap Int        @default(8)
  publicImageRadius Int    @default(8)
  clientEmail  String?
  clientAccessToken String? @unique
  proofingInviteSentAt DateTime?
  proofingInviteSentTo String?
  proofingInviteEmailError String?
  finalDeliveryEmailSentAt DateTime?
  finalDeliveryEmailSentTo String?
  finalDeliveryEmailError String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sections     GallerySection[]
  photos       Photo[]
  downloads    GalleryDownload[]
  downloadPackages GalleryDownloadPackage[]
  views        GalleryView[]
  favoriteLists GalleryFavoriteList[]
  sourceAlbumDesigns AlbumDesign[] @relation("AlbumDesignSourceGallery")
  uploadSessions GalleryUploadSession[]
  mediaProcessingJobs MediaProcessingJob[]
  purchases    GalleryPurchase[]
  admin        Admin   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  project      CustomerProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([customerId])
  @@index([projectId])
  @@index([galleryMode])
  @@index([galleryDesign])
  @@index([deliveryMode])
  @@index([proofingStatus])
}

model GalleryPurchase {
  id                      String   @id @default(cuid())
  galleryId               String
  adminId                 String
  email                   String
  name                    String?
  stripeAccountId         String
  stripeCheckoutSessionId String?  @unique
  stripePaymentIntentId   String?
  amountTotal             Int
  currency                String
  purchaseKind            String   @default("gallery")
  purchasedPhotoIds       Json?
  itemCount               Int      @default(0)
  status                  String   @default("pending")
  downloadScope           String?
  paidAt                  DateTime?
  fulfilledAt             DateTime?
  fulfillmentEmailSentAt  DateTime?
  fulfillmentError        String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  gallery                 Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  admin                   Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([adminId])
  @@index([email])
  @@index([status])
  @@index([purchaseKind])
  @@index([createdAt])
}

model GallerySection {
  id        String   @id @default(cuid())
  galleryId String
  title     String
  slug      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photos    Photo[]
  uploadSessions GalleryUploadSession[]

  @@unique([galleryId, slug])
  @@index([galleryId])
  @@index([galleryId, sortOrder])
}

model Photo {
  id           String   @id @default(cuid())
  galleryId    String
  sectionId    String?
  filename     String
  r2Key        String   @default("")
  imageUrl     String
  thumbnailUrl String
  previewUrl   String   @default("")
  deliveryStage String  @default("final")
  mediaType    String   @default("image")
  processingStatus String @default("ready")
  processingError  String?
  processingRequestedAt DateTime?
  processingCompletedAt DateTime?
  fileSize     Int      @default(0)
  imageWidth   Int      @default(0)
  imageHeight  Int      @default(0)
  sortOrder    Int      @default(0)
  capturedAt   DateTime?
  isClientHidden Boolean @default(false)
  clientHiddenAt DateTime?
  createdAt    DateTime @default(now())
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  section      GallerySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  favoriteItems GalleryFavoriteItem[]
  processingJobs MediaProcessingJob[]
  albumDesignItems AlbumDesignSpreadItem[]

  @@index([galleryId])
  @@index([sectionId])
  @@index([r2Key])
  @@index([galleryId, sortOrder])
  @@index([galleryId, sectionId])
  @@index([galleryId, deliveryStage])
  @@index([capturedAt])
  @@index([processingStatus])
}

model MediaProcessingJob {
  id           String   @id @default(cuid())
  galleryId    String
  photoId      String
  mediaType    String
  status       String   @default("pending")
  sourceR2Key  String
  thumbnailR2Key String?
  previewR2Key   String?
  posterR2Key    String?
  attempts     Int      @default(0)
  errorMessage String?
  claimedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photo        Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([photoId])
  @@index([status])
  @@index([createdAt])
  @@index([claimedAt])
}

model GalleryDownload {
  id        String   @id @default(cuid())
  galleryId String
  packageId String?
  email     String
  status    String   @default("recorded")
  downloadLinkSentAt DateTime?
  downloadLinkEmailError String?
  createdAt DateTime @default(now())
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  package   GalleryDownloadPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([galleryId])
  @@index([packageId])
  @@index([email])
  @@index([status])
}

model GalleryDownloadPackage {
  id           String   @id @default(cuid())
  galleryId    String
  scope        String   @default("public")
  status       String   @default("pending")
  photoCount   Int      @default(0)
  partIndex    Int      @default(0)
  partCount    Int      @default(1)
  photoOffset  Int      @default(0)
  photoLimit   Int?
  groupId      String?
  fileSize     BigInt   @default(0)
  processedCount Int     @default(0)
  processedBytes BigInt  @default(0)
  r2Key        String?
  downloadUrl  String?
  accessToken  String?  @unique
  accessTokenExpiresAt DateTime?
  linkCreatedAt DateTime?
  lastDownloadedAt DateTime?
  errorMessage String?
  generatedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  downloads    GalleryDownload[]

  @@index([galleryId])
  @@index([galleryId, scope])
  @@index([groupId])
  @@index([status])
  @@index([generatedAt])
  @@index([lastDownloadedAt])
}

model BackgroundJob {
  id           String   @id @default(cuid())
  type         String
  status       String   @default("pending")
  payload      Json
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  errorMessage String?
  lockedAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([lockedAt])
}

model GalleryView {
  id          String   @id @default(cuid())
  galleryId   String
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([createdAt])
  @@index([country])
}

model GalleryFavoriteList {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  name      String   @default("Favoriten")
  submittedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items     GalleryFavoriteItem[]
  albumDesigns AlbumDesign[]

  @@unique([galleryId, email, name])
  @@index([galleryId])
  @@index([email])
  @@index([submittedAt])
}

model GalleryFavoriteItem {
  id        String   @id @default(cuid())
  listId    String
  photoId   String
  createdAt DateTime @default(now())
  list      GalleryFavoriteList @relation(fields: [listId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([listId, photoId])
  @@index([photoId])
}

model GalleryUploadSession {
  id             String   @id @default(cuid())
  galleryId      String
  sectionId      String?
  status         String   @default("pending")
  deliveryStage  String   @default("final")
  totalCount     Int      @default(0)
  uploadedCount  Int      @default(0)
  completedCount Int      @default(0)
  failedCount    Int      @default(0)
  baseSortOrder  Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  gallery        Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  section        GallerySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  items          GalleryUploadItem[]

  @@index([galleryId])
  @@index([sectionId])
  @@index([status])
  @@index([createdAt])
}

model GalleryUploadItem {
  id            String   @id @default(cuid())
  sessionId     String
  clientId      String
  filename      String
  deliveryStage String   @default("final")
  r2Key         String?
  imageUrl      String?
  thumbnailUrl  String?
  previewUrl    String?
  mediaType     String   @default("image")
  fileSize      Int      @default(0)
  imageWidth    Int      @default(0)
  imageHeight   Int      @default(0)
  capturedAt    DateTime?
  originalIndex Int      @default(0)
  status        String   @default("pending")
  errorMessage  String?
  uploadedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  session       GalleryUploadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, clientId])
  @@index([sessionId])
  @@index([status])
  @@index([filename])
}
