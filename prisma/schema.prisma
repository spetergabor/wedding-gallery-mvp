generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("photographer")
  status       String   @default("pending")
  approvedAt   DateTime?
  approvedById String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  galleries    Gallery[]
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([readAt])
  @@index([createdAt])
}

model SiteSettings {
  id             String   @id @default("default")
  businessName   String   @default("")
  logoUrl        String?
  logoR2Key      String?
  signatureUrl   String?
  signatureR2Key String?
  websiteUrl     String?
  instagramUrl   String?
  facebookUrl    String?
  tiktokUrl      String?
  youtubeUrl     String?
  contactEmail   String?
  contactPhone   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Customer {
  id             String   @id @default(cuid())
  coupleName     String
  primaryEmail   String
  secondaryEmail String?
  phone          String?
  weddingDate    DateTime?
  venue          String?
  status         String   @default("lead")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contracts      Contract[]

  @@index([status])
  @@index([weddingDate])
  @@index([primaryEmail])
}

model Contract {
  id          String   @id @default(cuid())
  customerId  String
  title       String
  status      String   @default("draft")
  sourceType  String   @default("pdf")
  originalFilename String
  r2Key       String
  fileUrl     String
  fileSize    Int      @default(0)
  bodyText    String?
  clientFields Json?
  completedFields Json?
  accessToken String?  @unique
  accessTokenExpiresAt DateTime?
  sentAt      DateTime?
  openedAt    DateTime?
  signedAt    DateTime?
  signedR2Key String?
  signedFileUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
  @@index([accessToken])
}

model Gallery {
  id           String   @id @default(cuid())
  adminId      String?
  title        String
  slug         String   @unique
  password     String?
  eventDate    DateTime?
  isActive     Boolean  @default(false)
  coverPhotoId String?
  clientAccessToken String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photos       Photo[]
  downloads    GalleryDownload[]
  downloadPackages GalleryDownloadPackage[]
  views        GalleryView[]
  favoriteLists GalleryFavoriteList[]
  uploadSessions GalleryUploadSession[]
  mediaProcessingJobs MediaProcessingJob[]
  admin        Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
}

model Photo {
  id           String   @id @default(cuid())
  galleryId    String
  filename     String
  r2Key        String   @default("")
  imageUrl     String
  thumbnailUrl String
  previewUrl   String   @default("")
  mediaType    String   @default("image")
  processingStatus String @default("ready")
  processingError  String?
  processingRequestedAt DateTime?
  processingCompletedAt DateTime?
  fileSize     Int      @default(0)
  imageWidth   Int      @default(0)
  imageHeight  Int      @default(0)
  sortOrder    Int      @default(0)
  capturedAt   DateTime?
  isClientHidden Boolean @default(false)
  clientHiddenAt DateTime?
  createdAt    DateTime @default(now())
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  favoriteItems GalleryFavoriteItem[]
  processingJobs MediaProcessingJob[]

  @@index([galleryId])
  @@index([r2Key])
  @@index([galleryId, sortOrder])
  @@index([capturedAt])
  @@index([processingStatus])
}

model MediaProcessingJob {
  id           String   @id @default(cuid())
  galleryId    String
  photoId      String
  mediaType    String
  status       String   @default("pending")
  sourceR2Key  String
  thumbnailR2Key String?
  previewR2Key   String?
  posterR2Key    String?
  attempts     Int      @default(0)
  errorMessage String?
  claimedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photo        Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([photoId])
  @@index([status])
  @@index([createdAt])
  @@index([claimedAt])
}

model GalleryDownload {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  createdAt DateTime @default(now())
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([email])
}

model GalleryDownloadPackage {
  id           String   @id @default(cuid())
  galleryId    String
  status       String   @default("pending")
  photoCount   Int      @default(0)
  fileSize     Int      @default(0)
  r2Key        String?
  downloadUrl  String?
  errorMessage String?
  generatedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([status])
  @@index([generatedAt])
}

model BackgroundJob {
  id           String   @id @default(cuid())
  type         String
  status       String   @default("pending")
  payload      Json
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  errorMessage String?
  lockedAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([lockedAt])
}

model GalleryView {
  id          String   @id @default(cuid())
  galleryId   String
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([createdAt])
  @@index([country])
}

model GalleryFavoriteList {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  name      String   @default("Favoriten")
  submittedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items     GalleryFavoriteItem[]

  @@unique([galleryId, email, name])
  @@index([galleryId])
  @@index([email])
  @@index([submittedAt])
}

model GalleryFavoriteItem {
  id        String   @id @default(cuid())
  listId    String
  photoId   String
  createdAt DateTime @default(now())
  list      GalleryFavoriteList @relation(fields: [listId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([listId, photoId])
  @@index([photoId])
}

model GalleryUploadSession {
  id             String   @id @default(cuid())
  galleryId      String
  status         String   @default("pending")
  totalCount     Int      @default(0)
  uploadedCount  Int      @default(0)
  completedCount Int      @default(0)
  failedCount    Int      @default(0)
  baseSortOrder  Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  gallery        Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items          GalleryUploadItem[]

  @@index([galleryId])
  @@index([status])
  @@index([createdAt])
}

model GalleryUploadItem {
  id            String   @id @default(cuid())
  sessionId     String
  clientId      String
  filename      String
  r2Key         String?
  imageUrl      String?
  thumbnailUrl  String?
  previewUrl    String?
  mediaType     String   @default("image")
  fileSize      Int      @default(0)
  imageWidth    Int      @default(0)
  imageHeight   Int      @default(0)
  capturedAt    DateTime?
  originalIndex Int      @default(0)
  status        String   @default("pending")
  errorMessage  String?
  uploadedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  session       GalleryUploadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, clientId])
  @@index([sessionId])
  @@index([status])
  @@index([filename])
}
