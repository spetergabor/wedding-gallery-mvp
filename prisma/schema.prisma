generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([readAt])
  @@index([createdAt])
}

model Gallery {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  password     String?
  isActive     Boolean  @default(false)
  coverPhotoId String?
  clientAccessToken String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photos       Photo[]
  downloads    GalleryDownload[]
  views        GalleryView[]
  favoriteLists GalleryFavoriteList[]
}

model Photo {
  id           String   @id @default(cuid())
  galleryId    String
  filename     String
  r2Key        String   @default("")
  imageUrl     String
  thumbnailUrl String
  sortOrder    Int      @default(0)
  capturedAt   DateTime?
  isClientHidden Boolean @default(false)
  clientHiddenAt DateTime?
  createdAt    DateTime @default(now())
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  favoriteItems GalleryFavoriteItem[]

  @@index([galleryId])
  @@index([r2Key])
  @@index([galleryId, sortOrder])
  @@index([capturedAt])
}

model GalleryDownload {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  createdAt DateTime @default(now())
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([email])
}

model GalleryView {
  id          String   @id @default(cuid())
  galleryId   String
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([createdAt])
  @@index([country])
}

model GalleryFavoriteList {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items     GalleryFavoriteItem[]

  @@unique([galleryId, email])
  @@index([galleryId])
  @@index([email])
}

model GalleryFavoriteItem {
  id        String   @id @default(cuid())
  listId    String
  photoId   String
  createdAt DateTime @default(now())
  list      GalleryFavoriteList @relation(fields: [listId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([listId, photoId])
  @@index([photoId])
}
