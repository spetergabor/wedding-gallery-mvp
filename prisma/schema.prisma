generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([readAt])
  @@index([createdAt])
}

model Gallery {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  password     String?
  isActive     Boolean  @default(false)
  coverPhotoId String?
  clientAccessToken String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photos       Photo[]
  downloads    GalleryDownload[]
  downloadPackages GalleryDownloadPackage[]
  views        GalleryView[]
  favoriteLists GalleryFavoriteList[]
  uploadSessions GalleryUploadSession[]
}

model Photo {
  id           String   @id @default(cuid())
  galleryId    String
  filename     String
  r2Key        String   @default("")
  imageUrl     String
  thumbnailUrl String
  fileSize     Int      @default(0)
  imageWidth   Int      @default(0)
  imageHeight  Int      @default(0)
  sortOrder    Int      @default(0)
  capturedAt   DateTime?
  isClientHidden Boolean @default(false)
  clientHiddenAt DateTime?
  createdAt    DateTime @default(now())
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  favoriteItems GalleryFavoriteItem[]

  @@index([galleryId])
  @@index([r2Key])
  @@index([galleryId, sortOrder])
  @@index([capturedAt])
}

model GalleryDownload {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  createdAt DateTime @default(now())
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([email])
}

model GalleryDownloadPackage {
  id           String   @id @default(cuid())
  galleryId    String
  status       String   @default("pending")
  photoCount   Int      @default(0)
  fileSize     Int      @default(0)
  r2Key        String?
  downloadUrl  String?
  errorMessage String?
  generatedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([status])
  @@index([generatedAt])
}

model GalleryView {
  id          String   @id @default(cuid())
  galleryId   String
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([createdAt])
  @@index([country])
}

model GalleryFavoriteList {
  id        String   @id @default(cuid())
  galleryId String
  email     String
  name      String   @default("Favoriten")
  submittedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items     GalleryFavoriteItem[]

  @@unique([galleryId, email, name])
  @@index([galleryId])
  @@index([email])
  @@index([submittedAt])
}

model GalleryFavoriteItem {
  id        String   @id @default(cuid())
  listId    String
  photoId   String
  createdAt DateTime @default(now())
  list      GalleryFavoriteList @relation(fields: [listId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([listId, photoId])
  @@index([photoId])
}

model GalleryUploadSession {
  id             String   @id @default(cuid())
  galleryId      String
  status         String   @default("pending")
  totalCount     Int      @default(0)
  uploadedCount  Int      @default(0)
  completedCount Int      @default(0)
  failedCount    Int      @default(0)
  baseSortOrder  Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  gallery        Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  items          GalleryUploadItem[]

  @@index([galleryId])
  @@index([status])
  @@index([createdAt])
}

model GalleryUploadItem {
  id            String   @id @default(cuid())
  sessionId     String
  clientId      String
  filename      String
  r2Key         String?
  imageUrl      String?
  thumbnailUrl  String?
  fileSize      Int      @default(0)
  imageWidth    Int      @default(0)
  imageHeight   Int      @default(0)
  capturedAt    DateTime?
  originalIndex Int      @default(0)
  status        String   @default("pending")
  errorMessage  String?
  uploadedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  session       GalleryUploadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, clientId])
  @@index([sessionId])
  @@index([status])
  @@index([filename])
}
